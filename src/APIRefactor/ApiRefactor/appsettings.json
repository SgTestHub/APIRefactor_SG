{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ApiRefactor": "Information",
      "ApiRefactor.Data": "Debug",
      "ApiRefactor.Data.Repositories": "Debug",
      "ApiRefactor.Endpoints": "Information"
    }
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-change-this-in-production-must-be-at-least-32-characters-long",
    "Issuer": "ApiRefactor",
    "Audience": "ApiRefactorUsers",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*"
}

